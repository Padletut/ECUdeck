{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ECUDeck",
  "version": "0.1.0",
  "identifier": "com.ecudeck.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ECUDeck",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
